<!DOCTYPE html>
<html>
<head>
    <script src="https://telegram.org"></script>
    <style>
        body { background: #1a1a1a; color: white; font-family: sans-serif; text-align: center; }
        button { background: #0088cc; color: white; border: none; padding: 15px; border-radius: 10px; margin-top: 20px; }
    </style>
</head>
<body>
    <h1>GigaChat Mini App</h1>
    <p>Нажми кнопку, чтобы отправить данные боту</p>
    <button onclick="sendData()">Отправить привет боту</button>

    <script>
        let tg = window.Telegram.WebApp; // Получаем объект WebApp
        tg.expand(); // Расширяем на весь экран

        function sendData() {
            tg.sendData("Привет из Mini App!"); // Отправляет данные боту
            tg.close(); // Закрывает приложение
        }
    </script>
</body>
</html>
